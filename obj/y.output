Terminals which are not used

   STRCONST
   KWD_STRING
   OPER_NEG
   OPER_MOD
   OPER_AT
   OPER_INC
   OPER_DEC
   OPER_AND
   OPER_OR
   OPER_NOT
   ERROR
   ILLEGAL_TOK
   COMMENT
   NEWLINE
   WHITESPACE
   MULTLNCOMMENT


Grammar

    0 $accept: program $end

    1 program: declList

    2 declList: decl
    3         | declList decl

    4 decl: varDecl
    5     | funDecl

    6 typeSpecifier: KWD_INT
    7              | KWD_CHAR
    8              | KWD_VOID

    9 varDecl: typeSpecifier ID SEMICLN
   10        | typeSpecifier ID LSQ_BRKT INTCONST RSQ_BRKT SEMICLN

   11 funcTypeName: typeSpecifier ID

   12 formalDeclList: formalDecl
   13               | formalDecl COMMA formalDeclList

   14 formalDecl: typeSpecifier ID
   15           | typeSpecifier ID LSQ_BRKT RSQ_BRKT

   16 funDecl: funcTypeName LPAREN formalDeclList RPAREN LCRLY_BRKT localDeclList statementList RCRLY_BRKT
   17        | funcTypeName LPAREN RPAREN LCRLY_BRKT localDeclList statementList RCRLY_BRKT

   18 localDeclList: /* empty */
   19              | varDecl localDeclList

   20 statementList: /* empty */
   21              | statement statementList

   22 statement: compoundStmt
   23          | assignStmt
   24          | condStmt
   25          | loopStmt
   26          | returnStmt

   27 compoundStmt: LCRLY_BRKT statementList RCRLY_BRKT

   28 assignStmt: var OPER_ASGN expression SEMICLN
   29           | expression SEMICLN

   30 condStmt: KWD_IF LPAREN expression RPAREN statement
   31         | KWD_IF LPAREN expression RPAREN statement KWD_ELSE statement

   32 loopStmt: KWD_WHILE LPAREN expression RPAREN statement

   33 returnStmt: KWD_RETURN SEMICLN
   34           | KWD_RETURN expression SEMICLN

   35 expression: addExpr
   36           | expression relop addExpr

   37 relop: OPER_LTE
   38      | OPER_LT
   39      | OPER_GT
   40      | OPER_GTE
   41      | OPER_EQ
   42      | OPER_NEQ

   43 addExpr: term
   44        | addExpr addop term

   45 addop: OPER_ADD
   46      | OPER_SUB

   47 term: factor
   48     | term mulop factor

   49 mulop: OPER_MUL
   50      | OPER_DIV

   51 factor: LPAREN expression RPAREN
   52       | var
   53       | funCallExpr
   54       | INTCONST
   55       | CHARCONST

   56 var: ID
   57    | ID LSQ_BRKT addExpr RSQ_BRKT

   58 funCallExpr: ID LPAREN RPAREN
   59            | ID LPAREN argList RPAREN

   60 argList: expression
   61        | argList COMMA expression


